{
  "name": "@cv/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Editor UI (Vite + React) for the CV creator.",
  "scripts": {
    "sync:polyfill": "node scripts/sync-polyfill.mjs",
    "dev": "pnpm sync:polyfill && vite",
    "build": "pnpm sync:polyfill && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@cv/components": "workspace:*",
    "@cv/core": "workspace:*",
    "@cv/layout-engine": "workspace:*",
    "@cv/layouts": "workspace:*",
    "@cv/renderer": "workspace:*",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "i18next": "latest",
    "pagedjs": "latest",
    "react": "latest",
    "react-colorful": "^5.6.1",
    "react-dom": "latest",
    "react-i18next": "latest",
    "signature_pad": "^5.1.3",
    "zod": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@tailwindcss/vite": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "jsdom": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
